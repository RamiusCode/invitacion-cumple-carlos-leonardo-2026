---
// Despedida.astro - XV Años Varón Edition ✨
---

<section class="py-12 px-4 relative overflow-hidden">
  <div class="max-w-xl mx-auto text-center relative z-10">
    <div class="cal-card rounded-3xl p-8 md:p-10 relative" id="card-despedida">
      <!-- Destellos -->
      <div class="sparkle sparkle-1"></div>
      <div class="sparkle sparkle-2"></div>

      <!-- Esquinas azul eléctrico -->
      <div
        class="absolute top-3 left-3 w-10 h-10 border-t-2 border-l-2 border-blue-500/40"
      >
      </div>
      <div
        class="absolute top-3 right-3 w-10 h-10 border-t-2 border-r-2 border-blue-500/40"
      >
      </div>
      <div
        class="absolute bottom-3 left-3 w-10 h-10 border-b-2 border-l-2 border-blue-500/40"
      >
      </div>
      <div
        class="absolute bottom-3 right-3 w-10 h-10 border-b-2 border-r-2 border-blue-500/40"
      >
      </div>

      <div class="relative z-10 flex flex-col items-center gap-8">
        <!-- Texto confirmar -->
        <p
          class="font-cormorant text-2xl md:text-3xl font-bold texto-confirmar-titulo"
          id="mensaje-confirmar"
        >
          Por favor, haz clic para confirmar asistencia
        </p>

        <!-- BOTÓN -->
        <div id="boton-confirmar">
          <a
            href="https://wa.link/ab6zzp"
            target="_blank"
            rel="noopener noreferrer"
            class="boton-confirmar-custom"
            style="white-space:nowrap;"
          >
            <svg
              class="boton-icon"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
            <span
              class="font-cormorant text-lg font-bold boton-texto"
              style="white-space:nowrap;">Confirmar Asistencia</span
            >
            <span class="boton-brillo"></span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  if (typeof window !== "undefined") {
    document.addEventListener("DOMContentLoaded", () => {
      gsap.set("#card-despedida", { opacity: 0, y: 40, scale: 0.95 });
      gsap.set("#mensaje-confirmar", { opacity: 0, y: 20 });
      gsap.set("#boton-confirmar", { opacity: 0, scale: 0.8, y: 20 });

      ScrollTrigger.create({
        trigger: "#card-despedida",
        start: "top 85%",
        onEnter: () => {
          const tl = gsap.timeline();
          tl.to("#card-despedida", {
            opacity: 1,
            y: 0,
            scale: 1,
            duration: 0.8,
            ease: "power3.out",
          })
            .to(
              "#mensaje-confirmar",
              { opacity: 1, y: 0, duration: 0.7, ease: "power2.out" },
              "-=0.4",
            )
            .to(
              "#boton-confirmar",
              {
                opacity: 1,
                scale: 1,
                y: 0,
                duration: 0.7,
                ease: "back.out(1.5)",
              },
              "-=0.3",
            );

          // Pulso botón azul eléctrico
          gsap.to(".boton-confirmar-custom", {
            boxShadow:
              "0 0 28px rgba(65,105,255,0.9), 0 0 55px rgba(65,105,255,0.4)",
            duration: 2,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 1,
          });

          // Destellos
          gsap.to(".sparkle-1", {
            y: -6,
            opacity: 0.6,
            duration: 2.8,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
          });
          gsap.to(".sparkle-2", {
            y: -4,
            opacity: 0.4,
            duration: 3.4,
            ease: "sine.inOut",
            yoyo: true,
            repeat: -1,
            delay: 0.8,
          });
        },
        onLeaveBack: () => {
          gsap.set("#card-despedida", { opacity: 0, y: 40, scale: 0.95 });
          gsap.set("#mensaje-confirmar", { opacity: 0, y: 20 });
          gsap.set("#boton-confirmar", { opacity: 0, scale: 0.8, y: 20 });
        },
      });
    });
  }
</script>

<style>
  /* ─── CARD GLASSMORPHISM azul marino ─── */
  .cal-card {
    background: rgba(0, 4, 20, 0.4);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1.5px solid rgba(65, 105, 255, 0.35);
    box-shadow:
      0 8px 40px rgba(65, 105, 255, 0.2),
      inset 0 1px 0 rgba(65, 105, 255, 0.2);
    overflow: hidden;
    position: relative;
  }

  .cal-card::before {
    content: "";
    position: absolute;
    top: -1px;
    left: 10%;
    width: 80%;
    height: 2px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(65, 105, 255, 0.8),
      #fff,
      rgba(65, 105, 255, 0.8),
      transparent
    );
    border-radius: 50%;
  }

  .cal-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 50% 0%,
      rgba(65, 105, 255, 0.08) 0%,
      transparent 70%
    );
    pointer-events: none;
  }

  /* ─── TEXTO CONFIRMAR ─── */
  .texto-confirmar-titulo {
    color: #ffffff;
    text-shadow:
      0 0 4px #ffffff,
      0 0 10px #4169ff,
      0 0 22px #4169ff,
      0 0 45px #2233cc;
    animation: neonKF 3s ease-in-out infinite;
  }

  /* ─── BOTÓN ─── */
  .boton-confirmar-custom {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 36px;
    border-radius: 50px;
    background: linear-gradient(
      135deg,
      rgba(65, 105, 255, 0.25) 0%,
      rgba(255, 255, 255, 0.08) 50%,
      rgba(65, 105, 255, 0.25) 100%
    );
    border: 1.5px solid rgba(65, 105, 255, 0.7);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow:
      0 0 18px rgba(65, 105, 255, 0.4),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
    cursor: pointer;
    position: relative;
    overflow: hidden;
    text-decoration: none;
    transition:
      transform 0.3s ease,
      border-color 0.3s ease;
  }

  .boton-confirmar-custom:hover {
    transform: scale(1.06) translateY(-2px);
    border-color: rgba(65, 105, 255, 1);
  }

  .boton-icon {
    width: 24px;
    height: 24px;
    color: #00e8ff;
    filter: drop-shadow(0 0 6px rgba(0, 232, 255, 0.8));
    flex-shrink: 0;
  }

  .boton-texto {
    color: #ffffff;
    text-shadow:
      0 0 10px rgba(65, 105, 255, 0.8),
      0 1px 3px rgba(0, 0, 0, 0.3);
    letter-spacing: 0.05em;
  }

  .boton-brillo {
    position: absolute;
    top: 0;
    left: -75%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.2),
      transparent
    );
    transform: skewX(-20deg);
    transition: left 0.5s ease;
  }
  .boton-confirmar-custom:hover .boton-brillo {
    left: 125%;
  }

  /* ─── DESTELLOS ─── */
  .sparkle {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    opacity: 0.3;
  }
  .sparkle-1 {
    width: 5px;
    height: 5px;
    background: #4169ff;
    top: 8%;
    right: 8%;
    box-shadow: 0 0 8px 3px rgba(65, 105, 255, 0.7);
  }
  .sparkle-2 {
    width: 3px;
    height: 3px;
    background: #00e8ff;
    top: 15%;
    left: 10%;
    box-shadow: 0 0 6px 2px rgba(0, 232, 255, 0.5);
  }

  /* ─── NEÓN ─── */
  @keyframes neonKF {
    0%,
    100% {
      text-shadow:
        0 0 4px #fff,
        0 0 10px #4169ff,
        0 0 22px #4169ff,
        0 0 45px #2233cc;
    }
    50% {
      text-shadow:
        0 0 2px #fff,
        0 0 6px #2244dd,
        0 0 14px #2233bb;
    }
  }
</style>

---
// ReproductorMusica.astro - XV Años Varón Edition ✨
---

<div class="w-full max-w-sm mx-auto px-4 py-6" id="music-player-container">
  <div class="cal-card rounded-2xl px-6 py-5 relative" id="player-card">
    <!-- Borde neón girando — celeste brillante -->
    <div class="neon-border"></div>

    <div class="relative z-10 flex flex-col gap-4">
      <!-- Barra de progreso -->
      <div class="flex items-center gap-3">
        <span class="font-cormorant text-xs time-text" id="currentTime"
          >0:00</span
        >
        <input
          type="range"
          id="progressBar"
          value="0"
          max="100"
          class="flex-1 h-[3px] rounded-full appearance-none cursor-pointer slider-player"
        />
        <span class="font-cormorant text-xs time-text" id="totalDuration"
          >--:--</span
        >
      </div>

      <!-- Controles -->
      <div class="flex items-center justify-between px-1">
        <!-- Shuffle -->
        <button
          class="btn-control p-1.5 rounded-full transition-all duration-300"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="16 3 21 3 21 8"></polyline><polyline
              points="4 20 21 3"></polyline>
            <polyline points="21 16 21 21 16 21"></polyline><line
              x1="4"
              y1="4"
              x2="9"
              y2="9"></line>
          </svg>
        </button>

        <!-- Anterior -->
        <button
          id="prevBtn"
          class="btn-control p-1.5 rounded-full transition-all duration-300"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6 6h2v12H6zm3.5 6 8.5 6V6z"></path>
          </svg>
        </button>

        <!-- Play/Pause -->
        <button id="playPauseBtn" class="btn-play relative focus:outline-none">
          <div
            class="play-circle flex items-center justify-center w-12 h-12 rounded-full"
          >
            <svg
              id="play-icon"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M8 5v14l11-7z"></path>
            </svg>
            <svg
              id="pause-icon"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="hidden"
            >
              <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"></path>
            </svg>
          </div>
          <div
            class="absolute inset-0 rounded-full btn-play-glow pointer-events-none"
          >
          </div>
        </button>

        <!-- Siguiente -->
        <button
          id="nextBtn"
          class="btn-control p-1.5 rounded-full transition-all duration-300"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M6 18l8.5-6L6 6v12zm2-8.14L11.03 12 8 14.14V9.86zM16 6h2v12h-2z"
            ></path>
          </svg>
        </button>

        <!-- Repeat -->
        <button
          class="btn-control p-1.5 rounded-full transition-all duration-300"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="17 1 21 5 17 9"></polyline><path
              d="M3 11V9a4 4 0 0 1 4-4h14"></path>
            <polyline points="7 23 3 19 7 15"></polyline><path
              d="M21 13v2a4 4 0 0 1-4 4H3"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

<audio id="music-audio" preload="auto">
  <source src="/audio/ter.mp3" type="audio/mpeg" />
</audio>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  gsap.registerPlugin(ScrollTrigger);

  let isPlaying = false;
  let duration = 0;

  document.addEventListener("DOMContentLoaded", () => {
    gsap.set("#music-player-container", { opacity: 0, y: 20, scale: 0.97 });

    ScrollTrigger.create({
      trigger: "#music-player-container",
      start: "top 90%",
      onEnter: () => {
        gsap.to("#music-player-container", {
          opacity: 1,
          y: 0,
          scale: 1,
          duration: 0.7,
          ease: "back.out(1.4)",
        });
        gsap.to(".btn-play-glow", {
          boxShadow:
            "0 0 22px rgba(0,232,255,0.9), 0 0 45px rgba(0,232,255,0.5)",
          duration: 1.8,
          ease: "sine.inOut",
          yoyo: true,
          repeat: -1,
          delay: 0.8,
        });
      },
      onLeaveBack: () =>
        gsap.set("#music-player-container", { opacity: 0, y: 20, scale: 0.97 }),
    });

    const audio = document.getElementById("music-audio") as HTMLAudioElement;
    const playBtn = document.getElementById("playPauseBtn");
    const prevBtn = document.getElementById("prevBtn");
    const nextBtn = document.getElementById("nextBtn");
    const progressBar = document.getElementById(
      "progressBar",
    ) as HTMLInputElement;
    const playIcon = document.getElementById("play-icon");
    const pauseIcon = document.getElementById("pause-icon");

    audio?.addEventListener("loadedmetadata", () => {
      duration = audio.duration;
      updateTime();
    });

    playBtn?.addEventListener("click", () => {
      if (!isPlaying) {
        audio?.play();
        playIcon?.classList.add("hidden");
        pauseIcon?.classList.remove("hidden");
        gsap.to(".play-circle", {
          scale: 1.15,
          duration: 0.15,
          yoyo: true,
          repeat: 1,
        });
        isPlaying = true;
        startProgress();
      } else {
        audio?.pause();
        playIcon?.classList.remove("hidden");
        pauseIcon?.classList.add("hidden");
        isPlaying = false;
      }
    });

    prevBtn?.addEventListener("click", () =>
      gsap.to(prevBtn, { scale: 1.2, duration: 0.1, yoyo: true, repeat: 1 }),
    );
    nextBtn?.addEventListener("click", () =>
      gsap.to(nextBtn, { scale: 1.2, duration: 0.1, yoyo: true, repeat: 1 }),
    );

    progressBar?.addEventListener("input", () => {
      if (audio) {
        audio.currentTime = (Number(progressBar.value) / 100) * audio.duration;
        updateTime();
      }
    });

    function startProgress() {
      const iv = setInterval(() => {
        if (!isPlaying) {
          clearInterval(iv);
          return;
        }
        if (audio) {
          duration = audio.duration || duration;
          if (audio.currentTime >= duration) {
            isPlaying = false;
            playIcon?.classList.remove("hidden");
            pauseIcon?.classList.add("hidden");
            clearInterval(iv);
          }
          if (progressBar)
            progressBar.value = String(
              duration > 0 ? (audio.currentTime / duration) * 100 : 0,
            );
          updateTime();
        }
      }, 100);
    }

    function updateTime() {
      const cur = document.getElementById("currentTime");
      const tot = document.getElementById("totalDuration");
      if (audio && cur) {
        const m = Math.floor(audio.currentTime / 60);
        const s = Math.floor(audio.currentTime % 60);
        cur.textContent = `${m}:${s.toString().padStart(2, "0")}`;
      }
      if (audio?.duration && tot) {
        const m = Math.floor(audio.duration / 60);
        const s = Math.floor(audio.duration % 60);
        tot.textContent = `${m}:${s.toString().padStart(2, "0")}`;
      }
    }
  });
</script>

<style>
  /* ─── CARD TRANSPARENTE ─── */
  .cal-card {
    background: rgba(0, 4, 20, 0.25);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1.5px solid transparent;
    overflow: hidden;
    position: relative;
    box-shadow: 0 4px 30px rgba(0, 232, 255, 0.12);
  }

  /* ─── BORDE NEÓN CELESTE GIRANDO — MÁS VISIBLE ─── */
  .neon-border {
    position: absolute;
    inset: -2px;
    border-radius: inherit;
    background: conic-gradient(
      from var(--angle, 0deg),
      transparent 0%,
      transparent 30%,
      rgba(0, 232, 255, 0.3) 42%,
      rgba(0, 232, 255, 0.9) 48%,
      rgba(255, 255, 255, 1) 50%,
      rgba(0, 232, 255, 0.9) 52%,
      rgba(0, 232, 255, 0.3) 58%,
      transparent 70%,
      transparent 100%
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    padding: 2px;
    animation: rotateBorder 2s linear infinite;
    z-index: 0;
    filter: blur(0.5px);
  }

  @property --angle {
    syntax: "<angle>";
    initial-value: 0deg;
    inherits: false;
  }

  @keyframes rotateBorder {
    to {
      --angle: 360deg;
    }
  }

  /* Borde base fijo azul eléctrico */
  .cal-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    border: 1px solid rgba(65, 105, 255, 0.25);
    pointer-events: none;
    z-index: 1;
  }

  /* Resplandor de fondo celeste */
  .cal-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 50% 50%,
      rgba(0, 232, 255, 0.05) 0%,
      transparent 70%
    );
    pointer-events: none;
    z-index: 0;
  }

  /* ─── TEXTOS TIEMPO ─── */
  .time-text {
    color: rgba(0, 232, 255, 0.7);
  }

  /* ─── BOTONES ─── */
  .btn-control {
    color: rgba(65, 105, 255, 0.7);
    transition: all 0.25s ease;
  }
  .btn-control:hover {
    color: #00e8ff;
    background: rgba(0, 232, 255, 0.1);
    box-shadow: 0 0 10px rgba(0, 232, 255, 0.3);
    transform: scale(1.1);
  }

  /* ─── PLAY CIRCLE — azul eléctrico con glow celeste ─── */
  .play-circle {
    background: rgba(65, 105, 255, 0.85);
    box-shadow:
      0 0 16px rgba(65, 105, 255, 0.6),
      0 0 32px rgba(0, 232, 255, 0.3);
    color: #ffffff;
    transition: all 0.3s ease;
  }
  .play-circle:hover {
    background: rgba(65, 105, 255, 1);
    box-shadow:
      0 0 20px rgba(0, 232, 255, 0.6),
      0 0 40px rgba(65, 105, 255, 0.4);
  }

  .btn-play {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .btn-play-glow {
    border-radius: 50%;
  }

  /* ─── SLIDER — celeste ─── */
  .slider-player {
    background: rgba(0, 232, 255, 0.2);
    outline: none;
    cursor: pointer;
  }
  .slider-player::-webkit-slider-thumb {
    appearance: none;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #00e8ff;
    cursor: pointer;
    box-shadow: 0 0 8px rgba(0, 232, 255, 1);
    border: 1.5px solid rgba(255, 255, 255, 0.7);
  }
  .slider-player::-moz-range-thumb {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #00e8ff;
    border: 1.5px solid rgba(255, 255, 255, 0.7);
    box-shadow: 0 0 8px rgba(0, 232, 255, 1);
  }
</style>
